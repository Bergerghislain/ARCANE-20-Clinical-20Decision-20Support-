# Copier vers .env a la racine du depot :  cp .env.example .env
# Ne jamais committer .env (voir .gitignore).
# Ordre de chargement: backend_fastapi/.env puis .env racine (ce dernier l'emporte).
#
# Securite (production / labo) :
# - JWT_SECRET : chaine aleatoire longue (openssl rand -hex 32)
# - ALLOW_DEMO_PASSWORD_FALLBACK=false
# - COOKIE_SECURE=true si HTTPS
# - CORS_ORIGINS : liste stricte des origines navigateur autorisees
# - Ne pas exposer de cle LLM cote frontend (proxy backend uniquement)

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=remplacer_mot_de_passe_fort
DB_NAME=arcane
DB_CONNECT_TIMEOUT_SECONDS=15

# JWT / sessions
JWT_SECRET=remplacer_par_une_chaine_longue_aleatoire
JWT_ISSUER=arcane
JWT_AUDIENCE=arcane-client
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

PING_MESSAGE=ping

# Cookies (refresh token)
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Origines autorisees pour CORS (separees par des virgules, pas de wildcard *).
# Labo : remplacez par l'IP/hostname reel, ex. http://192.168.1.50:8000
# (pnpm build + pnpm start = SPA et API sur le meme port, une URL suffit souvent).
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Production / labo: mettre false
ALLOW_DEMO_PASSWORD_FALLBACK=false

# SQLAlchemy
SQLALCHEMY_ECHO=false
DB_IMPLEMENTATION=psycopg

# LLM: disabled | mock_json (JSON sans reseau, demos) | openai_compatible (vLLM, etc.)
LLM_PROVIDER=disabled
LLM_BASE_URL=http://127.0.0.1:8001/v1
LLM_API_KEY=
LLM_MODEL=Qwen/Qwen3-4B
LLM_TIMEOUT_SECONDS=120
# JSON mode (response_format json_object). true par defaut. Mettre false si votre
# endpoint OpenAI-compatible ne supporte pas response_format (compat large).
LLM_JSON_MODE=true
# Parametres de generation (optionnels)
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_MAX_TOKENS=1200

# Brancher un vrai modele (vLLM/Qwen) puis valider end-to-end :
#   export LLM_PROVIDER=openai_compatible LLM_BASE_URL=http://127.0.0.1:8001/v1
#   python backend_fastapi/scripts/llm_smoke.py --stream
# Sans GPU (stub OpenAI-compatible reseau, pour tester le vrai chemin HTTP) :
#   python backend_fastapi/scripts/fake_openai_server.py --port 8001
