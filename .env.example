# Copier vers .env a la racine du depot et adapter les valeurs.
# Ordre de chargement: backend_fastapi/.env puis .env racine (ce dernier l'emporte).

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=remplacer_mot_de_passe_fort
DB_NAME=arcane
DB_CONNECT_TIMEOUT_SECONDS=15

# JWT / sessions
JWT_SECRET=remplacer_par_une_chaine_longue_aleatoire
JWT_ISSUER=arcane
JWT_AUDIENCE=arcane-client
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

PING_MESSAGE=ping

# Cookies (refresh token)
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Origines autorisees pour CORS (separees par des virgules).
# Si le frontend est servi par le meme processus que l'API (pnpm build + pnpm start),
# les appels /api sont en meme origine: ajoutez quand meme l'URL publique du labo
# pour les outils ou un futur deploiement separe.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Production / labo: mettre false
ALLOW_DEMO_PASSWORD_FALLBACK=false

# SQLAlchemy
SQLALCHEMY_ECHO=false
DB_IMPLEMENTATION=psycopg

# LLM: disabled | mock_json (JSON sans reseau, demos) | openai_compatible (vLLM, etc.)
LLM_PROVIDER=disabled
LLM_BASE_URL=http://127.0.0.1:8001/v1
LLM_API_KEY=
LLM_MODEL=Qwen/Qwen3-4B
LLM_TIMEOUT_SECONDS=120
